rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. SAFETY NET ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isVerified() && request.auth.token.email == "zada.perfumes7@gmail.com"; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- 2. ENTITY VALIDATORS ---
    
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'image']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string &&
             data.price is number && data.price >= 0 &&
             data.image is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             (data.keys().hasAny(['role']) == false || data.role == 'customer'); // Prevent self-elevating to admin
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'customerInfo', 'items', 'total', 'status']) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status == 'pending';
    }

    // --- 3. MATCH BLOCKS ---

    // PRODUCTS
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(productId);
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(categoryId);
    }

    // DISCOUNTS
    match /discounts/{discountId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(discountId);
    }

    // SETTINGS
    match /settings/{settingId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(settingId);
    }

    // USERS
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // WISHLISTS
    match /wishlists/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && incoming().items is list && incoming().items.size() <= 50;
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ORDERS
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isVerified() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin(); // Only admins update orders (status etc)
      allow delete: if isAdmin();
    }
  }
}

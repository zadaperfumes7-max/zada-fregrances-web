rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isEmailVerified() && (
        request.auth.token.email == "zada.perfumes7@gmail.com" ||
        request.auth.uid == "kSqKKr0RkoRNVM7j2Sz0nXvVhqX2"
      ); 
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- 1. GLOBAL SAFETY & ADMIN ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- 2. STOREFRONT (Public) ---
    // Products, Categories, Settings, Discounts
    match /products/{productId} {
      allow read: if true;
    }
    match /categories/{categoryId} {
      allow read: if true;
    }
    match /settings/{settingId} {
      allow read: if true;
    }
    match /discounts/{discountId} {
      allow read: if true;
    }

    // --- 3. CUSTOMER DATA (Private) ---
    
    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && (
        incoming().keys().hasAll(['uid', 'email']) &&
        incoming().uid == userId &&
        incoming().email is string
      );
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
    }
    
    // Wishlists
    match /wishlists/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && (
        incoming().keys().hasAll(['items']) &&
        incoming().items is list &&
        incoming().items.size() <= 100
      );
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isEmailVerified() && (
        incoming().keys().hasAll(['userId', 'items', 'total', 'status']) &&
        incoming().userId == request.auth.uid &&
        incoming().status == 'pending'
      );
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Order items or sub-details
      match /{allPaths=**} {
        allow get: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.userId);
      }
    }
  }
}
